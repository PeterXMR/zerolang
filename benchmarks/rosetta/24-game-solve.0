fn can24 Bool a i32 b i32 c i32 d i32
  if == (* (+ a b) (- c d)) 24
    ret true
  if == (+ (+ a b) (+ c d)) 24
    ret true
  if == (* (- a b) (+ c d)) 24
    ret true
  ret false

pub fn main Void world World !
  if && (&& (can24 1 3 9 3) (can24 6 6 6 6)) (== (can24 1 1 1 1) false)
    check world.out.write "24 solve ok\n"
