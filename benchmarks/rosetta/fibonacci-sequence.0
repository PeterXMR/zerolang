fn fib u32 n u32
  mut index u32 0
  mut a u32 0
  mut b u32 1
  while < index n
    let next + a b
    set a b
    set b next
    set index + index 1
  ret a

fn fibSum u32 max u32
  mut index u32 0
  mut sum u32 0
  while <= index max
    set sum + sum (fib index)
    set index + index 1
  ret sum

pub fn main Void world World !
  if && (&& (&& (== (fib 0) 0) (== (fib 1) 1)) (&& (== (fib 2) 1) (== (fib 10) 55))) (== (fibSum 10) 143)
    check world.out.write "fibonacci ok\n"
