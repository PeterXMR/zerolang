pub fn main Void world World !
  mut table [95]u8 [0_u8;95]
  mut code u8 32
  mut i usize 0
  while <= code 126
    set table[i] code
    set code + code 1
    set i + i 1
  if && (&& (== table[0] 32) (== table[33] 65)) (&& (== table[58] 90) (== table[94] 126))
    check world.out.write "ascii table ok\n"
