fn dist2 i32 ax i32 ay i32 bx i32 by i32
  let dx - ax bx
  let dy - ay by
  ret + (* dx dx) (* dy dy)

pub fn main Void world World !
  let xs [4]i32 [0, 4, 8, (- 0 2)]
  let ys [4]i32 [0, 4, 8, 5]
  mut best usize 0
  mut bestDist i32 dist2 xs[0] ys[0] 5 5
  mut i usize 1
  while < i 4
    let d dist2 xs[i] ys[i] 5 5
    if < d bestDist
      set best i
      set bestDist d
    set i + i 1
  if && (== (dist2 0 0 3 4) 25) (== best 1)
    check world.out.write "kd tree ok\n"
